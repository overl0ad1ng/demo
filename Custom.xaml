<local:MyHint Margin="0,0,0,0" Theme="Blue"
                    Text="欢迎来到魔法小镇 MagicTown！&#xA;这是专门为魔法小镇提供的优质模组整合包，如果在使用过程中出现任何疑问，可以在群里向大家提问！" />

<local:MyHint Margin="0,5,0,0" Theme="Yellow" Text="进去如果发现右上角出现一大块遮挡视野的色块，可以按下 F8（默认键位设置）关闭。这是花卉地图（Flower Map）模组。" />

<local:MyHint Margin="0,5,0,15" Theme="Yellow" Text="默认会打开背包显示，可以按下 i关闭或在模组菜单里搜索 Inventory HUD 进行修改" />

<local:MyCard Title="默认键位设置" Margin="0,0,0,15" CanSwap="True" IsSwapped="True">
    <StackPanel Margin="25,40,23,15">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="X+C" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开 Tweakeroo 配置界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="H+C" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开 MiniHud 配置界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="K+C" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开 TweakerooMore 配置界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="M" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开 Litematic 配置界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="V" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开语音配置界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text="G" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开语音群组界面" Margin="0,0,5,0" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,4">
            <TextBlock TextWrapping="Wrap" Text=", (逗号)" Margin="5,0" Background="{DynamicResource ColorBrush7}" />
            <TextBlock TextWrapping="Wrap" Text="打开大地图" Margin="0,0,5,0" />
        </StackPanel>
    </StackPanel>
</local:MyCard>

<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
